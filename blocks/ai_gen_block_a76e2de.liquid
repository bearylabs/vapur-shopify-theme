{% doc %}
  @prompt
    Ein horizontal verteiltes feature grid für Kostenloser versand, sichere bezahlung und einfache retouren. Es sollen die Shopify farbschemas verwendet werden, ändere die icons und mache die icons links vom text. Icons: Versand = Truck, Sichere BEzahlung = schloss und Retoiuren = Kreis mit pfeil, das einfache retouren icon soll wie dieses recylce icon sein. Und richte das gesamte div mittig aus, sodass es mehr zentriert ist
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: rgb(var(--color-background));
  }

  .ai-feature-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.gap }}px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    justify-items: center;
  }

  .ai-feature-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    align-items: center;
    text-align: left;
    gap: {{ block.settings.item_gap }}px;
    justify-content: center;
  }

  .ai-feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgb(var(--color-foreground));
  }

  .ai-feature-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
  }

  .ai-feature-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0;
    color: rgb(var(--color-foreground));
  }

  .ai-feature-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    color: rgba(var(--color-foreground), 0.75);
  }

  @media screen and (max-width: 749px) {
    .ai-feature-grid-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-feature-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

<feature-grid-{{ ai_gen_id }} class="ai-feature-grid-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-grid-container-{{ ai_gen_id }}">
    <div class="ai-feature-item-{{ ai_gen_id }}">
      <div class="ai-feature-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path>
          <path d="M15 18H9"></path>
          <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path>
          <circle cx="17" cy="18" r="2"></circle>
          <circle cx="7" cy="18" r="2"></circle>
        </svg>
      </div>
      <div class="ai-feature-content-{{ ai_gen_id }}">
        <h3 class="ai-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_1_title }}</h3>
        <p class="ai-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_1_description }}</p>
      </div>
    </div>

    <div class="ai-feature-item-{{ ai_gen_id }}">
      <div class="ai-feature-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
      </div>
      <div class="ai-feature-content-{{ ai_gen_id }}">
        <h3 class="ai-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_2_title }}</h3>
        <p class="ai-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_2_description }}</p>
      </div>
    </div>

    <div class="ai-feature-item-{{ ai_gen_id }}">
      <div class="ai-feature-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
          <path d="M21 3v5h-5"></path>
          <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
          <path d="M3 21v-5h5"></path>
        </svg>
      </div>
      <div class="ai-feature-content-{{ ai_gen_id }}">
        <h3 class="ai-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_3_title }}</h3>
        <p class="ai-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_3_description }}</p>
      </div>
    </div>
  </div>
</feature-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class FeatureGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('feature-grid-{{ ai_gen_id }}', FeatureGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Feature grid",
  "settings": [
    {
      "type": "header",
      "content": "Feature 1"
    },
    {
      "type": "text",
      "id": "feature_1_title",
      "label": "Title",
      "default": "Kostenloser Versand"
    },
    {
      "type": "text",
      "id": "feature_1_description",
      "label": "Description",
      "default": "Ab 50€ Bestellwert"
    },
    {
      "type": "header",
      "content": "Feature 2"
    },
    {
      "type": "text",
      "id": "feature_2_title",
