{% doc %}
  @prompt
    a vertical grit for features like free shipping, and secure payment, i mean horiziontal
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-features-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-features-grid__list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    gap: {{ block.settings.item_spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .ai-features-grid__item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    border: {{ block.settings.item_border_thickness }}px solid {{ block.settings.item_border_color }};
    flex: 1 1 auto;
    min-width: 200px;
  }

  .ai-features-grid__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.icon_color }};
  }

  .ai-features-grid__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-features-grid__content-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-features-grid__title-{{ ai_gen_id }} {
    margin: 0 0 4px 0;
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
  }

  .ai-features-grid__description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-features-grid-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-features-grid__list-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-features-grid__item-{{ ai_gen_id }} {
      min-width: 100%;
    }
  }
{% endstyle %}

<feature-grid-{{ ai_gen_id }}
